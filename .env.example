# Example .env file — copy this to `.env` and fill secrets for local development
# Do NOT commit your real `.env` to source control.

# SECRET_KEY: a random secret string used for sessions and CSRF signing.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# FLASK_ENV: 'development' or 'production' (development will generate an ephemeral key if SECRET_KEY is empty)
FLASK_ENV=development
